{
  "expo": {
    "name": "Organic Nagaland",
    "slug": "organic-nagaland",
    "scheme": "organic-nagaland",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#72A01C",
          "sounds": [
            "./assets/sounds/Argon.wav",
            "./assets/sounds/BrightMorning.wav",
            "./assets/sounds/Carbon.wav"
          ]
        }
      ]
    ],
    "orientation": "portrait",
    "icon": "./assets/splash.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.idan.orgaincb2b",
      "buildNumber": "1.0.0"
    },
    "android": {
      "package": "com.idan.orgaincb2b",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/splash.png",
        "backgroundColor": "#FFFFFF"
      },
      "useNextNotificationsApi": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
